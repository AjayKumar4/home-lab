{
"Version": "2012-10-17",
"Statement": [
  {
      "Effect": "Allow",
      "Action": [
          "s3:DeleteObject",
          "s3:GetObject",
          "s3:ListBucket",
          "s3:PutObject"
      ],
      "Resource": [
          {% for bucket in minio_backup_name %}
          "arn:aws:s3:::{{ bucket }}",
          "arn:aws:s3:::{{ bucket }}/*"
          {% endfor %}
      ]
  }  
]
}